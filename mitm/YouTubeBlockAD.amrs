# YouTube 去广告 - Anywhere MITM RuleSet

name = YouTube去广告
hostname = youtubei.googleapis.com, googlevideo.com

0, 100, ^https://[^/]+/initplayback.*[?&]oad(?:[=&]|$), 
0, 100, ^https://[^/]+/youtubei/v1/(?:browse|player|search|guide)(?:\?|$), 
0, 2, ^https://[^/]+/youtubei/v1/(?:browse|next|player|search|reel/reel_watch_sequence|guide|account/get_setting|get_watch)(?:\?|$), accept-encoding
0, 1, ^https://[^/]+/youtubei/v1/(?:browse|next|player|search|reel/reel_watch_sequence|guide|account/get_setting|get_watch)(?:\?|$), accept-encoding, identity
1, 100, ^https://[^/]+/youtubei/v1/(?:browse|next|player|search|reel/reel_watch_sequence|guide|account/get_setting|get_watch)(?:\?|$), 
