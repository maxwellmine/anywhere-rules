# Bilibili 去广告 - Anywhere MITM RuleSet

name = Bilibili去广告
hostname = grpc.biliapi.net, app.bilibili.com, api.bilibili.com, api.live.bilibili.com, line3-h5-mobile-api.biligame.com

0, 2, ^https://[^/]+/(?:pgc/page/channel|x/(?:v2/splash/(?:list|show|event/list2)|resource/show/tab/v2))(?:\?|$), accept-encoding
0, 1, ^https://[^/]+/(?:pgc/page/channel|x/(?:v2/splash/(?:list|show|event/list2)|resource/show/tab/v2))(?:\?|$), accept-encoding, identity
0, 2, ^https://[^/]+/x/v2/feed/index(?:/story)?(?:\?|$), accept-encoding
0, 1, ^https://[^/]+/x/v2/feed/index(?:/story)?(?:\?|$), accept-encoding, identity
0, 2, ^https://[^/]+/bilibili\.(?:polymer\.app\.search\.v1\.Search/SearchAll|main\.community\.reply\.v1\.Reply/MainList)(?:\?|$), accept-encoding
0, 1, ^https://[^/]+/bilibili\.(?:polymer\.app\.search\.v1\.Search/SearchAll|main\.community\.reply\.v1\.Reply/MainList)(?:\?|$), accept-encoding, identity
0, 100, ^https://[^/]+/(?:x/(?:resource/(?:top/activity|patch/tab(?:/v2)?)|v2/search/square|vip/ads/materials)|pgc/activity/deliver/material/receive|xlive/e-commerce-interface/v1/ecommerce-user/get_shopping_info|game/live/large_card_material|bilibili\.app\.(?:interface\.v1\.(?:Teenagers/ModeStatus|Search/DefaultWords)|view\.v1\.View/TFInfo|viewunite\.v1\.View/(?:PlayPause|ViewEndPage)))(?:\?|$), 
1, 100, ^https://[^/]+/(?:pgc/page/channel|x/(?:v2/splash/(?:list|show|event/list2)|resource/show/tab/v2))(?:\?|$), 
1, 100, ^https://[^/]+/x/v2/feed/index(?:/story)?(?:\?|$), 
1, 100, ^https://[^/]+/bilibili\.(?:polymer\.app\.search\.v1\.Search/SearchAll|main\.community\.reply\.v1\.Reply/MainList)(?:\?|$), 
