# Spotify 解锁/去广告 - Anywhere MITM RuleSet

name = Spotify解锁
hostname = spclient.wg.spotify.com, spclient.spotify.com, spotify.com

0, 2, ^https://[^/]+/user-customization-service/v1/customize(?:\?|$), if-none-match
0, 0, ^https://(?:\w+-spclient|spclient\.wg)\.spotify\.com(?::443)?/(?:pendragon/|ad(?:[/?]|$)), 2, {}
0, 2, ^https://[^/]+/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), accept-encoding
0, 1, ^https://[^/]+/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), accept-encoding, identity
0, 100, ^https://[^/]+/(?:artistview/v1/artist|album-entity-view/v2/album)/.*[?&]platform=iphone(?:&|$), 
1, 100, ^https://[^/]+/(?:bootstrap/v1/bootstrap|user-customization-service/v1/customize)(?:\?|$), 
